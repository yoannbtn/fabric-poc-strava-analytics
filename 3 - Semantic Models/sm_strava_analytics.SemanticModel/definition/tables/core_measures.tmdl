	measure 'Activities Average Run Pace (min/km)' = ```
			
			DIVIDE (
			    [Activities Total Moving Time (min)], 
			    [Activities Total Distance (km)], 
			    0
			)
			```
		displayFolder: _Activities\_Averages
		lineageTag: 20e24a8a-5aea-4877-bfbb-eb8f254da43d

		formatStringDefinition =
				VAR CurrentPace = [Activities Average Run Pace (min/km)]
				RETURN
				    IF (
				        ISBLANK ( CurrentPace ) || CurrentPace <= 0,
				        "0:00 min/km",
				        VAR TotalSeconds = CurrentPace * 60
				        VAR Minutes = INT ( DIVIDE ( TotalSeconds, 60 ) )
				        VAR Seconds = ROUND ( MOD ( TotalSeconds, 60 ), 0 )
				        RETURN
				            FORMAT ( Minutes, "0" ) & ":" & FORMAT ( Seconds, "00" ) & " min/km"
				    )

	measure 'Activities Average Speed (km/h)' = ```
			
			DIVIDE (
			    [Activities Total Distance (km)], 
			    [Activities Total Moving Time (min)] / 60, 
			    0
			)
			```
		formatString: " 0.0 ""km/h"""
		displayFolder: _Activities\_Averages
		lineageTag: 72c89510-7738-4f71-a059-830731b83856

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Activities Total Moving Time (h min)' =
			
			VAR TotalMinutes = [Activities Total Moving Time (min)]
			VAR Hours = INT ( TotalMinutes / 60 )
			VAR Minutes = MOD ( TotalMinutes, 60 )
			RETURN
			    SWITCH (
			        TRUE (),
			        Hours > 0, FORMAT ( Hours, "0" ) & "h " & FORMAT ( Minutes, "00" ) & "min",
			        Minutes > 0, FORMAT ( Minutes, "0" ) & "min",
			        BLANK ()
			    )
		displayFolder: _Activities\_Totals
		lineageTag: 303d37b2-544a-4918-aa77-ba276115acef

